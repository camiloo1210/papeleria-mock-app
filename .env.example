# =============================================================================
#  Fiado Canal Digital — Variables de entorno (plantilla, SIN valores reales)
#  Copia este archivo a .env y completa los valores.
# =============================================================================

# --- Mock mode (desarrollo sin Supabase) --------------------------------------
# Pon NEXT_PUBLIC_USE_MOCK=true para usar datos locales en lugar de Supabase.
# Con NEXT_PUBLIC_USE_MOCK=true las variables de Supabase pueden quedar vacías.
NEXT_PUBLIC_USE_MOCK=false

# --- Supabase -----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- WhatsApp Business Cloud API ----------------------------------------------
# Tokens GLOBALES (verificación de webhook y validación de firma).
# El phone_number_id y el access_token POR TENANT se guardan en la base de datos
# (tabla whatsapp_config) vía el panel de configuración, NO aquí.
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# --- Google Generative AI (BI / insights del dashboard) -----------------------
# Usado por @ai-sdk/google (modelo gemini) en /api/bi/insights.
GOOGLE_GENERATIVE_AI_API_KEY=

# --- Upstash Redis (rate limiting) --------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Lemon Squeezy (PAGOS) ----------------------------------------------------
# NOTA IMPORTANTE: en el repositorio ORIGEN NO existe integración con Lemon
# Squeezy. Los pedidos del marketplace se registran a crédito ("fiado"). Estas
# variables quedan como PLACEHOLDER para una futura integración. Ver:
#   packages/core/src/features/marketplace/payments/lemon-squeezy.placeholder.ts
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_SIGNING_SECRET=
LEMON_SQUEEZY_STORE_ID=

# --- Sentry (observabilidad, opcional) ----------------------------------------
NEXT_PUBLIC_SENTRY_DSN=

# --- App ----------------------------------------------------------------------
# URL pública del sitio (usada para enlaces absolutos / callbacks).
NEXT_PUBLIC_SITE_URL=
