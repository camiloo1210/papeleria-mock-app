{
    "name": "fiado-canal-digital",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "dev": "turbo run dev",
        "dev:web": "turbo run dev --filter=@fiado/web",
        "build": "turbo run build",
        "lint": "turbo run lint",
        "type-check": "turbo run type-check",
        "test": "turbo run test",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "clean": "rimraf node_modules apps/*/.next apps/*/.turbo packages/*/.turbo packages/*/dist"
    },
    "devDependencies": {
        "@typescript-eslint/eslint-plugin": "^8.50.1",
        "@typescript-eslint/parser": "^8.50.1",
        "dotenv-cli": "^11.0.0",
        "eslint": "^8.57.1",
        "prettier": "^3.0.0",
        "turbo": "^2.8.12",
        "typescript": "5.4.5"
    },
    "packageManager": "pnpm@10.24.0",
    "pnpm": {
        "overrides": {
            "react": "19.2.4",
            "react-dom": "19.2.4",
            "@types/react": "~19.2.3",
            "@types/react-dom": "~19.2.3",
            "next": "^15.5.14",
            "axios": "^1.7.9"
        }
    }
}
